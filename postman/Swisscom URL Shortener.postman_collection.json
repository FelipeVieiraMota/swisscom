        {
          "name": "List current user's links",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Links are returned', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Created link belongs to the list', () => {",
                  "  pm.expect(body.some(link => link.id === pm.environment.get('linkId'))).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "links"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get link by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Owned link is returned', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Correct link is returned', () => pm.expect(body.id).to.eql(pm.environment.get('linkId')));",
                  "pm.test('Link starts active', () => pm.expect(body.active).to.eql(true));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links/{{linkId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "links",
                "{{linkId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Resolve public short link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Public endpoint redirects', () => pm.response.to.have.status(302));",
                  "pm.test('Redirect target is correct', () => pm.expect(pm.response.headers.get('Location')).to.eql(pm.environment.get('originalUrl')));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/r/{{shortCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "r",
                "{{shortCode}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Verify click counter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Link is returned after redirect', () => pm.response.to.have.status(200));",
                  "pm.test('Click was counted', () => pm.expect(pm.response.json().clickCount).to.be.at.least(1));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links/{{linkId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "links",
                "{{linkId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Deactivate link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Link is deactivated', () => pm.response.to.have.status(204));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links/{{linkId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "links",
                "{{linkId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Reject deactivated short link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Deactivated link is no longer public', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/r/{{shortCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "r",
                "{{shortCode}}"
              ]
            }
          },
          "response": []
