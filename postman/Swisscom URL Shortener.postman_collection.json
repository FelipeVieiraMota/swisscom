{
  "info": {
    "_postman_id": "b2fa08c9-5402-4e06-89a7-cfbf48884cb1",
    "name": "Swisscom URL Shortener",
    "description": "End-to-end test flow through the HTTPS Gateway. Run folders in order or execute the complete collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Smoke",
      "item": [
        {
          "name": "Gateway health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Gateway is healthy', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('UP');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "01 - Authentication",
      "item": [
        {
          "name": "Login as development admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin login succeeds', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Admin access token is returned', () => {",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.tokenType).to.eql('Bearer');",
                  "});",
                  "pm.environment.set('adminToken', body.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Register a test user (ADMIN only)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('userEmail', `candidate.${Date.now()}@example.com`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User is created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Created user has USER role', () => pm.expect(body.roles).to.include('USER'));",
                  "pm.environment.set('userId', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "{{adminToken}}", "type": "string"}]
            },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login as test user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User login succeeds', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('User access token is returned', () => pm.expect(body.accessToken).to.be.a('string').and.not.empty);",
                  "pm.environment.set('userToken', body.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Get authenticated user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Current user is returned', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('JWT subject matches the registered user', () => pm.expect(body.userId).to.eql(pm.environment.get('userId')));",
                  "pm.test('JWT contains USER role', () => pm.expect(body.roles).to.include('USER'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "02 - Links",
      "item": [
        {
          "name": "Create short link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Short link is created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Short code is returned', () => pm.expect(body.shortCode).to.be.a('string').and.not.empty);",
                  "pm.expect(pm.response.headers.get('Location')).to.include(body.id);",
                  "pm.environment.set('linkId', body.id);",
                  "pm.environment.set('shortCode', body.shortCode);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]
            },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"{{originalUrl}}\",\n  \"expiresAt\": null\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/links",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "links"]
            }
          }
        },
        {
          "name": "List current user's links",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Links are returned', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Created link belongs to the list', () => {",
                  "  pm.expect(body.some(link => link.id === pm.environment.get('linkId'))).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "links"]
            }
          }
        },
        {
          "name": "Get link by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Owned link is returned', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Correct link is returned', () => pm.expect(body.id).to.eql(pm.environment.get('linkId')));",
                  "pm.test('Link starts active', () => pm.expect(body.active).to.eql(true));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links/{{linkId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "links", "{{linkId}}"]
            }
          }
        },
        {
          "name": "Resolve public short link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Public endpoint redirects', () => pm.response.to.have.status(302));",
                  "pm.test('Redirect target is correct', () => pm.expect(pm.response.headers.get('Location')).to.eql(pm.environment.get('originalUrl')));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/r/{{shortCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["r", "{{shortCode}}"]
            }
          },
          "protocolProfileBehavior": {"followRedirects": false}
        },
        {
          "name": "Verify click counter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Link is returned after redirect', () => pm.response.to.have.status(200));",
                  "pm.test('Click was counted', () => pm.expect(pm.response.json().clickCount).to.be.at.least(1));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links/{{linkId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "links", "{{linkId}}"]
            }
          }
        },
        {
          "name": "Deactivate link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Link is deactivated', () => pm.response.to.have.status(204));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links/{{linkId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "links", "{{linkId}}"]
            }
          }
        },
        {
          "name": "Reject deactivated short link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Deactivated link is no longer public', () => pm.response.to.have.status(404));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/r/{{shortCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["r", "{{shortCode}}"]
            }
          },
          "protocolProfileBehavior": {"followRedirects": false}
        }
      ]
    },
    {
      "name": "03 - Authorization checks",
      "item": [
        {
          "name": "Reject link creation without JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('JWT is required', () => pm.response.to.have.status(401));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"{{originalUrl}}\",\n  \"expiresAt\": null\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/links",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "links"]
            }
          }
        },
        {
          "name": "Reject registration by regular user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('ADMIN role is required', () => pm.response.to.have.status(403));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "{{userToken}}", "type": "string"}]
            },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"unauthorized.{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        }
      ]
    }
  ]
}
