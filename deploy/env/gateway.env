# =========================
# SERVER
# =========================
SERVER_PORT=80
SPRING_APPLICATION_NAME=gateway
SPRING_PROFILES_ACTIVE=docker

# =========================
# SPRING BOOT ADMIN
# =========================
SPRING_BOOT_ADMIN_CLIENT_URL=http://observability:10000
SPRING_BOOT_ADMIN_INSTANCE_SERVICE_URL=http://gateway:80
SPRING_BOOT_ADMIN_INSTANCE_MANAGEMENT_URL=http://gateway:80/actuator
SPRING_BOOT_ADMIN_INSTANCE_HEALTH_URL=http://gateway:80/actuator/health

# =========================
# GATEWAY
# =========================
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:3000
GATEWAY_CORS_ALLOWED_METHODS=*
GATEWAY_CORS_ALLOWED_HEADERS=*
AUTH_SERVICE_URI=lb://authenticator

# =========================
# EUREKA
# =========================
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true
EUREKA_DEFAULT_ZONE=http://discovery:8761/eureka/
EUREKA_INSTANCE_HOSTNAME=gateway
EUREKA_INSTANCE_PREFER_IP_ADDRESS=false
EUREKA_INSTANCE_NON_SECURE_PORT=80
EUREKA_INSTANCE_STATUS_PAGE_URL_PATH=/actuator/info
EUREKA_INSTANCE_HEALTH_CHECK_URL_PATH=/actuator/health
EUREKA_INSTANCE_MANAGEMENT_CONTEXT_PATH=/actuator

# =========================
# LOGGING
# =========================
LOGGING_LEVEL_GATEWAY=INFO
LOGGING_LEVEL_NETFLIX_DISCOVERY=INFO
LOGGING_LEVEL_NETFLIX_EUREKA=INFO
LOGGING_LEVEL_SPRING_CLOUD_NETFLIX_EUREKA=INFO
