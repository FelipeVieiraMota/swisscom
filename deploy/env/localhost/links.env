SERVER_PORT=5000
SPRING_APPLICATION_NAME=links
SPRING_PROFILES_ACTIVE=localhost

SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

APP_SECURITY_JWT_ISSUER=swisscom-authenticator
APP_SECURITY_JWT_AUDIENCE=swisscom-api

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/links
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/
EUREKA_CLIENT_REGISTER_WITH_EUREKA=true
EUREKA_CLIENT_FETCH_REGISTRY=true

SPRING_BOOT_ADMIN_CLIENT_URL=http://localhost:10000
SPRING_BOOT_ADMIN_CLIENT_ENABLED=true
SPRING_BOOT_ADMIN_CLIENT_AUTO_REGISTRATION=true
