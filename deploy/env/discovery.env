# =========================
# SERVER
# =========================
SERVER_PORT=8761
SPRING_APPLICATION_NAME=discovery
SPRING_PROFILES_ACTIVE=docker

# =========================
# SPRING BOOT ADMIN
# =========================
SPRING_BOOT_ADMIN_CLIENT_URL=http://observability:10000
SPRING_BOOT_ADMIN_INSTANCE_SERVICE_URL=http://discovery:8761
SPRING_BOOT_ADMIN_INSTANCE_MANAGEMENT_URL=http://discovery:8761/actuator
SPRING_BOOT_ADMIN_INSTANCE_HEALTH_URL=http://discovery:8761/actuator/health

# =========================
# EUREKA
# =========================
EUREKA_REGISTER_WITH_EUREKA=true
EUREKA_FETCH_REGISTRY=true
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true
EUREKA_INSTANCE_HOSTNAME=discovery
EUREKA_INSTANCE_NON_SECURE_PORT=8761

# =========================
# LOGGING
# =========================
LOGGING_LEVEL_NETFLIX_DISCOVERY=INFO
LOGGING_LEVEL_NETFLIX_EUREKA=INFO
LOGGING_LEVEL_SPRING_CLOUD_NETFLIX_EUREKA=INFO
