# DEV always runs inside Docker.
SERVER_PORT=4000
SPRING_APPLICATION_NAME=authenticator
SPRING_PROFILES_ACTIVE=dev

APP_SECURITY_JWT_ACCESS_TOKEN_TTL=15m
APP_SECURITY_JWT_ISSUER=swisscom-authenticator
APP_SECURITY_JWT_AUDIENCE=swisscom-api
APP_SECURITY_PUBLIC_PATHS=/api/v1/auth/login,/api/v1/auth/api-docs/**,/api/v1/auth/swagger-ui/**,/swagger-ui/**,/actuator/**,/error
APP_BOOTSTRAP_ADMIN_EMAIL=admin@swisscom.local
APP_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe-Admin-2026!

EUREKA_DEFAULT_ZONE=http://discovery:8761/eureka/
EUREKA_CLIENT_REGISTER_WITH_EUREKA=true
EUREKA_CLIENT_FETCH_REGISTRY=true

SPRING_BOOT_ADMIN_CLIENT_URL=http://observability:10000
SPRING_BOOT_ADMIN_CLIENT_AUTO_REGISTRATION=true
SPRING_BOOT_ADMIN_CLIENT_ENABLED=true
SPRING_BOOT_ADMIN_CLIENT_INSTANCE_SERVICE_URL=https://auth.localhost/api/v1/auth/swagger-ui

SPRING_DATASOURCE_URL=jdbc:postgresql://auth-postgres:5432/authenticator
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

LOGGING_LEVEL_SECURITY=INFO
LOGGING_LEVEL_WEB=INFO
