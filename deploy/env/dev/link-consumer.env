# DEV always runs inside Docker.
SERVER_PORT=5100
SPRING_APPLICATION_NAME=link-consumer
SPRING_PROFILES_ACTIVE=dev

SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672

SPRING_DATASOURCE_URL=jdbc:postgresql://links-postgres:5432/links
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_FLYWAY_ENABLED=false

EUREKA_DEFAULT_ZONE=http://discovery:8761/eureka/
EUREKA_CLIENT_REGISTER_WITH_EUREKA=true
EUREKA_CLIENT_FETCH_REGISTRY=true

SPRING_BOOT_ADMIN_CLIENT_URL=http://observability:10000
SPRING_BOOT_ADMIN_CLIENT_AUTO_REGISTRATION=true
SPRING_BOOT_ADMIN_CLIENT_ENABLED=true
SPRING_BOOT_ADMIN_CLIENT_INSTANCE_SERVICE_URL=http://link-consumer:5100

LOGGING_LEVEL_WEB=INFO
